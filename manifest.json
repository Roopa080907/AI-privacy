{
  "manifest_version": 3,
  "name": "AI Privacy Keyboard Guard",
  "version": "1.0",
  "description": "Detects sensitive data in real time",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}